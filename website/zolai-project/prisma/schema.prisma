// ── New Duolingo-style curriculum hierarchy ───────────────────────────────────

model CurriculumSection {
  id             String           @id @default(cuid())
  levelCode      String // A1 | A2 | B1 | B2 | C1 | C2
  number         Int // 1–4 = content, 5 = daily refresh
  name           String
  isDailyRefresh Boolean          @default(false)
  vocabMin       Int
  vocabMax       Int
  order          Int              @default(0)
  createdAt      DateTime         @default(now())
  units          CurriculumUnit[]

  @@unique([levelCode, number])
  @@index([levelCode])
  @@map("curriculum_section")
}

model CurriculumUnit {
  id          String              @id @default(cuid())
  sectionId   String
  number      Int
  topic       String
  description String?
  xpReward    Int                 @default(50)
  order       Int                 @default(0)
  createdAt   DateTime            @default(now())
  section     CurriculumSection   @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  subUnits    CurriculumSubUnit[]

  @@unique([sectionId, number])
  @@index([sectionId])
  @@map("curriculum_unit")
}

model CurriculumSubUnit {
  id        String                @id @default(cuid())
  unitId    String
  number    Int // 1–8
  title     String
  type      SubUnitType
  xpReward  Int                   @default(10)
  order     Int                   @default(0)
  content   Json // LessonContent[]
  createdAt DateTime              @default(now())
  unit      CurriculumUnit        @relation(fields: [unitId], references: [id], onDelete: Cascade)
  progress  UserSubUnitProgress[]

  @@unique([unitId, number])
  @@index([unitId])
  @@map("curriculum_sub_unit")
}

model UserSubUnitProgress {
  id          String            @id @default(cuid())
  userId      String
  subUnitId   String
  status      ProgressStatus    @default(NOT_STARTED)
  score       Int               @default(0)
  xpEarned    Int               @default(0)
  attempts    Int               @default(0)
  completedAt DateTime?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  subUnit     CurriculumSubUnit @relation(fields: [subUnitId], references: [id], onDelete: Cascade)
  user        User              @relation("UserSubUnitProgress", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, subUnitId])
  @@index([userId, status])
  @@map("user_sub_unit_progress")
}

// ── Phonics track ─────────────────────────────────────────────────────────────

model PhonicsUnit {
  id          String           @id @default(cuid())
  category    PhonicsCategory
  number      Int
  title       String
  description String?
  ipaSymbol   String?
  audioUrl    String?
  order       Int              @default(0)
  createdAt   DateTime         @default(now())
  subUnits    PhonicsSubUnit[]

  @@unique([category, number])
  @@index([category])
  @@map("phonics_unit")
}

model PhonicsSubUnit {
  id        String                @id @default(cuid())
  unitId    String
  number    Int // 1–8
  title     String
  type      String // PhonicsLessonType
  content   Json // PhonicsLesson[]
  audioUrl  String?
  order     Int                   @default(0)
  createdAt DateTime              @default(now())
  unit      PhonicsUnit           @relation(fields: [unitId], references: [id], onDelete: Cascade)
  progress  UserPhonicsProgress[]

  @@unique([unitId, number])
  @@index([unitId])
  @@map("phonics_sub_unit")
}

model UserPhonicsProgress {
  id          String         @id @default(cuid())
  userId      String
  subUnitId   String
  status      ProgressStatus @default(NOT_STARTED)
  score       Int            @default(0)
  xpEarned    Int            @default(0)
  completedAt DateTime?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  subUnit     PhonicsSubUnit @relation(fields: [subUnitId], references: [id], onDelete: Cascade)
  user        User           @relation("UserPhonicsProgress", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, subUnitId])
  @@index([userId])
  @@map("user_phonics_progress")
}

model LessonUnit {
  id          String     @id @default(cuid())
  planId      String
  title       String
  description String?
  order       Int        @default(0)
  xpReward    Int        @default(10)
  lessons     Lesson[]
  plan        LessonPlan @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@index([planId, order])
  @@map("lesson_unit")
}

model Lesson {
  id       String               @id @default(cuid())
  unitId   String
  title    String
  type     LessonType
  content  Json
  xpReward Int                  @default(5)
  order    Int                  @default(0)
  unit     LessonUnit           @relation(fields: [unitId], references: [id], onDelete: Cascade)
  progress UserLessonProgress[]

  @@index([unitId, order])
  @@map("lesson")
}

model UserLessonProgress {
  id            String         @id @default(cuid())
  userId        String
  lessonId      String
  status        ProgressStatus @default(NOT_STARTED)
  score         Int            @default(0)
  xpEarned      Int            @default(0)
  attempts      Int            @default(0)
  lastAttemptAt DateTime?
  completedAt   DateTime?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  lesson        Lesson         @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  user          User           @relation("UserLessonProgress", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId])
  @@index([userId, status])
  @@index([userId, completedAt])
  @@map("user_lesson_progress")
}

model UserStreak {
  id             String    @id @default(cuid())
  userId         String    @unique
  currentStreak  Int       @default(0)
  longestStreak  Int       @default(0)
  totalXp        Int       @default(0)
  lastActivityAt DateTime?
  user           User      @relation("UserStreak", fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_streak")
}

model AgentMemory {
  id        String    @id @default(cuid())
  userId    String
  agentId   String
  key       String
  value     Json
  expiresAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  user      User      @relation("UserAgentMemory", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, agentId, key])
  @@index([userId, agentId])
  @@map("agent_memory")
}

model AgentLearnLog {
  id        String   @id @default(cuid())
  agentId   String
  taskType  String
  input     Json?
  output    Json?
  feedback  String?
  lesson    String?
  createdAt DateTime @default(now())

  @@index([agentId, taskType])
  @@index([createdAt])
  @@map("agent_learn_log")
}

model InboundEmail {
  id        String    @id @default(cuid())
  to        String // which inbox received it (hello@, support@, admin@)
  from      String
  fromName  String?
  subject   String
  text      String?
  html      String?
  replyTo   String?
  isRead    Boolean   @default(false)
  isReplied Boolean   @default(false)
  repliedAt DateTime?
  createdAt DateTime  @default(now())

  @@index([to, createdAt])
  @@index([isRead])
  @@map("inbound_email")
}

