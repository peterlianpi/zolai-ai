{
  "name": "zolai-language-hub",
  "version": "0.1.0",
  "private": true,
  "description": "Zolai Language Hub - Comprehensive resources for learning and preserving the Zolai (Tedim Chin) language",
  "scripts": {
    "dev": "node scripts/update-dev-ip.mjs && next dev --hostname 0.0.0.0",
    "build": "next build",
    "postinstall": "bun prisma generate",
    "start": "next start",
    "lint": "eslint",
    "audit:features": "bun scripts/audit-features.ts",
    "audit:system": "bunx tsx scripts/audit-system.ts",
    "audit:multi": "bunx tsx scripts/audit-multi-agent.ts",
    "audit:all": "bun run audit:system && bun run audit:multi",
    "pre-deploy": "bunx tsx scripts/pre-deploy.ts",
    "deploy": "bash scripts/deploy.sh",
    "check-deployment": "node check-deployment.js",
    "test": "playwright test",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:headed": "playwright test --headed",
    "test:ui": "playwright test --ui",
    "test:debug": "playwright test --debug",
    "test:auth": "playwright test tests/auth/",
    "test:api": "playwright test tests/api/",
    "test:admin": "playwright test tests/admin/",
    "test:e2e": "playwright test tests/e2e/",
    "test:performance": "playwright test tests/performance/",
    "test:security": "playwright test tests/api/api-security.spec.ts",
    "test:report": "playwright show-report",
    "test:install": "playwright install --with-deps",
    "test:seed": "tsx tests/fixtures/seed-test-data.ts",
    "test:cleanup": "tsx tests/fixtures/seed-test-data.ts cleanup",
    "seed:notifications": "tsx scripts/create-notification-templates.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.88.0",
