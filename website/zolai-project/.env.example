# Database
DATABASE_URL="postgres://username:password@host:5432/database"

# Application URLs
BETTER_AUTH_URL='http://localhost:3000'
NEXT_PUBLIC_SITE_URL=https://zolai.peterlianpi.site
NEXT_PUBLIC_API_URL=http://13.115.84.100:18789
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Better Auth
BETTER_AUTH_SECRET="your-secret-key-here"
BETTER_AUTH_API_KEY="your-api-key-here"

# App Configuration
NEXT_PUBLIC_APP_NAME="Zolai AI"

# Security Features (Team Delta)
# CAPTCHA Protection
HCAPTCHA_SECRET_KEY="your-hcaptcha-secret-key"
NEXT_PUBLIC_HCAPTCHA_SITE_KEY="your-hcaptcha-site-key"

# Alternative CAPTCHA providers (optional)
RECAPTCHA_SECRET_KEY="your-recaptcha-secret-key"
NEXT_PUBLIC_RECAPTCHA_SITE_KEY="your-recaptcha-site-key"
TURNSTILE_SECRET_KEY="your-turnstile-secret-key"
NEXT_PUBLIC_TURNSTILE_SITE_KEY="your-turnstile-site-key"

# IP Geolocation (optional)
IP_GEOLOCATION_API_KEY="your-ip-geolocation-api-key"

# SMTP (Gmail example)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM="Zolai AI <your-email@gmail.com>"

# Resend (optional - used when RESEND_API_KEY is set; falls back to SMTP)
RESEND_API_KEY=""
RESEND_FROM_EMAIL="onboarding@resend.dev"

# Test Mode (optional - uncomment to enable)
# TEST_SEND_TO_MAIL=your-test-email@example.com
# TEST_CRON_INTERVAL_MINUTES=5

# Cron Jobs (optional)
ENABLE_CRON_SECRET_CHECK=false
CRON_SECRET="your-cron-secret"

# File Upload
MEDIA_UPLOAD_PROVIDER="s3" # cloudinary | r2 | s3
MAX_UPLOAD_SIZE_MB=5

# Cloudinary (when MEDIA_UPLOAD_PROVIDER=cloudinary)
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_UPLOAD_PRESET="your-upload-preset"
CLOUDINARY_API_KEY="your-cloudinary-api-key"
CLOUDINARY_API_SECRET="your-cloudinary-api-secret"

# R2 (when MEDIA_UPLOAD_PROVIDER=r2)
R2_ENDPOINT="https://<ACCOUNT_ID>.r2.cloudflarestorage.com"
R2_BUCKET_NAME="your-bucket-name"
R2_ACCESS_KEY_ID="your-r2-access-key-id"
R2_SECRET_ACCESS_KEY="your-r2-secret-access-key"
R2_PUBLIC_URL="https://pub-<HASH>.r2.dev"

# S3 (when MEDIA_UPLOAD_PROVIDER=s3)
S3_REGION="ap-southeast-1"
S3_BUCKET_NAME="your-s3-bucket-name"
S3_ACCESS_KEY_ID="your-s3-access-key-id"
S3_SECRET_ACCESS_KEY="your-s3-secret-access-key"
S3_PUBLIC_URL="https://your-bucket-name.s3.ap-southeast-1.amazonaws.com"

# Zolai AI — Data Paths
ZOLAI_DATA_PATH=/home/peter/Documents/Projects/zolai/data
ZOLAI_WIKI_PATH=/home/peter/Documents/Projects/zolai/wiki
ZOLAI_BIBLE_PATH=/home/peter/Documents/Projects/zolai/Cleaned_Bible/Parallel

# Zolai AI — LLM API (upstream chat/tutor service)
ZOLAI_API_URL=http://13.115.84.100:18789/chat

# Monitoring Configuration
MONITOR_PERFORMANCE_TIME_RANGE=1h
MONITOR_STATS_CACHE_TTL_MS=5000
MONITOR_METRICS_RESET_INTERVAL_MS=300000
MONITOR_REDIS_DETAILED_TTL_SECONDS=3600
MONITOR_REDIS_AGGREGATE_TTL_SECONDS=86400
MONITOR_REDIS_CACHE_TTL_SECONDS=86400
MONITOR_SLOW_QUERY_THRESHOLD_MS=100
MONITOR_PROCESS_CLOCK_TICKS=100
MONITOR_PROCESS_CPU_TIME_DIVISOR=10000
MONITOR_MEMORY_WARNING_PERCENT=90
MONITOR_MEMORY_CRITICAL_PERCENT=95
MONITOR_DISK_WARNING_PERCENT=85
MONITOR_DISK_CRITICAL_PERCENT=95
MONITOR_CPU_WARNING_PERCENT=80
MONITOR_HEAP_WARNING_MB=400
MONITOR_ALERT_DEDUP_WINDOW_MS=300000
MONITOR_ALERT_MAX_RETRIES=3
MONITOR_ALERT_RETRY_BASE_MS=1000
MONITOR_ALERT_RETRY_MAX_MS=10000
MONITOR_QUIET_HOURS_START=-1
MONITOR_QUIET_HOURS_END=-1
MONITOR_MAINTENANCE_MODE=false
MONITOR_ENABLE_RECOVERY_ALERTS=true
MONITOR_HEARTBEAT_ENABLED=true
MONITOR_CHAT_ID_INFO=
MONITOR_CHAT_ID_WARNING=
MONITOR_CHAT_ID_CRITICAL=

# Telegram Delivery Controls
TELEGRAM_TIMEOUT_MS=30000
TELEGRAM_DISABLE_WEB_PREVIEW=true
TELEGRAM_MAX_MESSAGE_CHARS=3900

# Contact email (used in JSON-LD and contact page)
NEXT_PUBLIC_CONTACT_EMAIL=contact@zolai.ai
