# Zolai Unified Project Environment (example)
# Copy to .env and fill in your values

ZOLAI_ROOT=/path/to/zolai
ZOLAI_DATA_ROOT=/path/to/zolai/data
ZOLAI_API_HOST=127.0.0.1
ZOLAI_API_PORT=8300
ZOLAI_GUI_THEME=dark

# Optional: API Keys
# HF_TOKEN=hf_xxxxx
# KAGGLE_USERNAME=your_username
# KAGGLE_KEY=your_key
# GITHUB_TOKEN=ghp_xxxxx
