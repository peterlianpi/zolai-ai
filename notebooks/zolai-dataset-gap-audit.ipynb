   "source": [
    "## Recommended audit workflow (manual + numbers)\n",
    "\n",
    "1. **List 5\u201310 production scenarios** (styles/domains your model must handle). Use the checklist cell below.\n",
    "2. **Skim stratified samples** (random + keyword-filtered) in this notebook.\n",
    "3. **Read the summary stats**: length distribution, ASCII/Latin ratio (proxy for English noise), digit ratio.\n",
    "4. **If something is rare or dirty**, that is a candidate *gap* or *quality* issue \u2014 decide: more data, better filtering, or targeted crawl (only with a clear source list and rights).\n",
    "5. **Optional:** run the small **Gemini qualitative pass** on a tiny sample (last section) \u2014 costs API tokens; use for ideas, not ground truth.\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# 3) Streaming stats (memory-safe)\n",
    "\n",
    "\n",
    "def ascii_latin_ratio(s: str) -> float:\n",
    "    if not s:\n",
    "        return 0.0\n",
    "    n = sum(1 for c in s if ord(c) < 128 and (c.isalpha() or c.isspace()))\n",
    "    return n / max(len(s), 1)\n",
    "\n",
    "\n",
    "def audit_jsonl(path: Path, max_lines=None, seed=42):\n",
    "    rng = random.Random(seed)\n",
    "    lengths_words = []\n",
    "    lengths_chars = []\n",
    "    ascii_ratios = []\n",
    "    digit_lines = 0\n",
    "    url_like = 0\n",
    "    empty = 0\n",
    "    n = 0\n",
    "    vocab_sample = []\n",
    "    bigrams = Counter()\n",
    "    sources = Counter()\n",
    "    RE_URL = re.compile(r\"https?://|www\\\\.\", re.I)\n",
    "\n",
    "    from tqdm.auto import tqdm\n",
    "    with open(path, \"r\", encoding=\"utf-8\", errors=\"replace\") as f:\n",
    "        for line in tqdm(f, desc=\"Auditing\", unit=\"line\", mininterval=2.0):\n",
    "            if max_lines is not None and n >= max_lines:\n",
    "                break\n",

    "            n += 1\n",
    "            try:\n",
    "                obj = json.loads(line)\n",
    "                t = (obj.get(\"text\") or \"\").strip()\n",
    "            except Exception:\n",
    "                continue\n",
    "            if not t:\n",
    "                empty += 1\n",
    "                continue\n",
    "            words = t.split()\n",
    "            w_lower = [w.lower() for w in words]\n",
    "            lengths_words.append(len(words))\n",
    "            lengths_chars.append(len(t))\n",
    "            ascii_ratios.append(ascii_latin_ratio(t))\n",
    "            if RE_URL.search(t):\n",
    "                url_like += 1\n",
    "            if any(c.isdigit() for c in t):\n",
    "                digit_lines += 1\n",
    "            \n",
    "            # Vocab and N-grams\n",
    "            if len(vocab_sample) < 50_000:\n",
    "                vocab_sample.extend(w_lower[:200])\n",
    "            \n",
    "            # Streaming bigrams for noise detection (sample to save memory)\n",
    "            if rng.random() < 0.1:\n",
    "                for i in range(len(w_lower) - 1):\n",
    "                    bigrams[f\"{w_lower[i]} {w_lower[i+1]}\"] += 1\n",
    "\n",
    "            src = obj.get(\"source\") or obj.get(\"refiner\") or \"\"\n",
    "            if src:\n",
    "                sources[str(src)[:80]] += 1\n",
    "            if rng.random() < 0.002 and len(vocab_sample) < 100_000:\n",
    "                vocab_sample.extend(words)\n",
    "\n",
    "    p50 = sorted(lengths_words)[len(lengths_words) // 2] if lengths_words else 0\n",
    "    p90 = sorted(lengths_words)[int(len(lengths_words) * 0.9)] if lengths_words else 0\n",
    "    \n",
    "    unique_tokens = len(set(vocab_sample))\n",
    "    ttr = unique_tokens / max(len(vocab_sample), 1)\n",
    "\n",
    "    # Domain Heatmap (Simple Keyword Heuristic)\n",
    "    domain_counts = Counter()\n",
    "    religious_kw = {\"pasian\", \"zeisu\", \"siampite\", \"biakna\", \"israel\", \"abraham\", \"thutak\"}\n",
    "    stem_kw = {\"computer\", \"science\", \"technology\", \"math\", \"physics\", \"logic\", \"engine\"}\n",
    "    \n",
    "    for w in vocab_sample:\n",
    "        if w in religious_kw: domain_counts[\"Religious\"] += 1\n",
    "        elif w in stem_kw: domain_counts[\"STEM/Technical\"] += 1\n",
    "        else: domain_counts[\"General\"] += 1\n",
    "\n",
    "    return {\n",
    "        \"lines_read\": n,\n",
    "        \"non_empty\": n - empty,\n",
    "        \"empty\": empty,\n",
    "        \"avg_words\": sum(lengths_words) / max(len(lengths_words), 1),\n",
    "        \"p50_words\": p50,\n",
    "        \"p90_words\": p90,\n",
    "        \"avg_chars\": sum(lengths_chars) / max(len(lengths_chars), 1),\n",
    "        \"mean_ascii_ratio\": sum(ascii_ratios) / max(len(ascii_ratios), 1),\n",
    "        \"linguistic_richness_ttr\": ttr,\n",
    "        \"lines_with_digit\": digit_lines,\n",
    "        \"lines_url_like\": url_like,\n",
    "        \"domain_heatmap\": domain_counts.most_common(),\n",
    "        \"sources_top\": sources.most_common(12),\n",
    "        \"top_bigrams\": bigrams.most_common(20),\n",
    "        \"vocab_sample_size\": len(vocab_sample),\n",
    "    }, lengths_words, vocab_sample\n",
    "\n",
    "\n",
    "cap = SAMPLE_LINES_FOR_STATS\n",
    "summary, lengths_words, vocab_sample = audit_jsonl(INPUT_JSONL, max_lines=cap, seed=RANDOM_SEED)\n",
    "\n",
    "print(\"--- Summary (first\", cap if cap else \"all\", \"lines) ---\")\n",
    "for k, v in summary.items():\n",
    "    if k not in (\"sources_top\", \"top_bigrams\"):\n",
    "        print(f\"  {k}: {v}\")\n",
    "\n",
    "print(\"\\n--- Top Sources ---\")\n",
    "for s, c in summary[\"sources_top\"][:8]:\n",
    "    print(f\"  {c:,} | {s}\")\n",
    "\n",
    "print(\"\\n--- Top Bigrams (Potential Noise/Patterns) ---\")\n",
    "for b, c in summary[\"top_bigrams\"]:\n",
    "    print(f\"  {c:,} | {b}\")\n",
    "\n",
    "cw = Counter(vocab_sample)\n",
    "print(\"\\nTop 25 tokens (sample):\")\n",
    "for w, c in cw.most_common(25):\n",
    "    print(f\"  {w[:40]!r}: {c:,}\")\n"
   ]
  },
