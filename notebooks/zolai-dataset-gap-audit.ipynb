  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# 5) Stratified peek \u2014 random + optional keyword filter\n",
    "\n",
    "\n",
    "def reservoir_peek(path, k=30, max_scan=200_000, seed=42):\n",
    "    rng = random.Random(seed)\n",
    "    buf = []\n",
    "    scanned = 0\n",
    "    with open(path, \"r\", encoding=\"utf-8\", errors=\"replace\") as f:\n",
    "        for line in f:\n",
    "            scanned += 1\n",
    "            if scanned > max_scan:\n",
    "                break\n",
    "            try:\n",
    "                t = (json.loads(line).get(\"text\") or \"\").strip()\n",
    "            except Exception:\n",
    "                continue\n",
    "            if not t:\n",
    "                continue\n",
    "            if len(buf) < k:\n",
    "                buf.append(t)\n",
    "            else:\n",
    "                j = rng.randint(0, scanned - 1)\n",
    "                if j < k:\n",
    "                    buf[j] = t\n",
    "    return buf, scanned\n",
    "\n",
    "\n",
    "random_lines, nscan = reservoir_peek(INPUT_JSONL, k=STRATIFIED_PEEK, max_scan=500_000, seed=RANDOM_SEED)\n",
    "print(f\"Reservoir sample from first ~{nscan} lines scanned, k={len(random_lines)}\\n\")\n",
    "for i, t in enumerate(random_lines[:STRATIFIED_PEEK], 1):\n",
    "    print(f\"[{i}] {t[:280]}{'...' if len(t)>280 else ''}\\n\")\n",
    "\n",
    "# Keyword-filtered peek (edit pattern for your gap hunt, e.g. English UI)\n",
    "KW = re.compile(r\"(?i)\\b(the|and|for|login|password|cookie)\\b\")\n",
    "kw_hits = []\n",
    "with open(INPUT_JSONL, \"r\", encoding=\"utf-8\", errors=\"replace\") as f:\n",
    "    for line in f:\n",
    "        try:\n",
    "            t = (json.loads(line).get(\"text\") or \"\")\n",
    "        except Exception:\n",
    "            continue\n",
    "        if KW.search(t):\n",
    "            kw_hits.append(t.strip())\n",
    "            if len(kw_hits) >= KEYWORD_PEEK:\n",
    "                break\n",
    "print(\"--- Lines matching English/boilerplate heuristic (first\", KEYWORD_PEEK, \") ---\")\n",
    "for i, t in enumerate(kw_hits, 1):\n",
    "    print(f\"[kw {i}] {t[:300]}...\")\n"
   ]
  },
