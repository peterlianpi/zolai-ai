   "source": [
    "# 2) Paths \u2014 same layout as zolai-cleaner-v2 / combiner\n",
    "import os\n",
    "import re\n",
    "import json\n",
    "import random\n",
    "from collections import Counter\n",
    "from pathlib import Path\n",
    "\n",
    "IS_KAGGLE = Path(\"/kaggle\").exists()\n",
    "WORK_DIR = Path(\"/kaggle/working\" if IS_KAGGLE else os.environ.get(\"ZOLOAI_WORK_DIR\", \".\")).resolve()\n",
    "OUT_DIR = WORK_DIR / \"zolai_audit_out\"\n",
    "OUT_DIR.mkdir(parents=True, exist_ok=True)\n",
    "\n",
    # Where to scan for inputs (Kaggle datasets mount)\n",
         "DATASETS_ROOT = Path(os.environ.get(\"ZOLOAI_DATASETS_ROOT\", \"/kaggle/input\"))\n"
    "\n",
    "# Override: path to one JSONL (each line: {\"text\": \"...\", ...})\n",
    "AUDIT_JSONL = os.environ.get(\"ZOLOAI_AUDIT_JSONL\", \"\").strip()\n",
    "\n",
    "def discover_inputs(root: Path) -> list[Path]:\n",
    "    candidates = []\n",
    "    if root.exists():\n",
    "        # 1. Scan Kaggle inputs for any .jsonl\n",
    "        candidates.extend(list(root.rglob(\"*.jsonl\")))\n",
    "    \n",
    "    # 2. Check working dir outputs from cleaner/combiner\n",
    "    for extra in (WORK_DIR / \"zolai_cleaner_out\", WORK_DIR / \"zolai_combine_out\", WORK_DIR):\n",
    "        if extra.is_dir():\n",
    "            candidates.extend(list(extra.glob(\"*.jsonl\")))\n",
    "    \n",
    "    # Priority sorting: favor cleaner outputs or merged files\n",
    "    def priority(p: Path):\n",
    "        n = p.name.lower()\n",
    "        if \"merged_all\" in n: return 0\n",
    "        if \"after_gemini\" in n: return 1\n",
    "        if \"train_ready\" in n: return 2\n",
    "        if \"train\" in n: return 3\n",
    "        return 10\n",
    "    \n",
    "    return sorted(set(candidates), key=lambda x: (priority(x), x.name))\n",
    "\n",
    "if AUDIT_JSONL:\n",
    "    INPUT_JSONL = Path(AUDIT_JSONL)\n",
    "else:\n",
    "    cands = discover_inputs(DATASETS_ROOT)\n",
    "    INPUT_JSONL = cands[0] if cands else WORK_DIR / \"zolai_cleaner_out\" / \"zolai_train_ready_v2.jsonl\"\n",
    "\n",
    "RANDOM_SEED = 42\n",
    "SAMPLE_LINES_FOR_STATS = 2_000_000  # Increase for better 'whole dataset' stats\n",
    "STRATIFIED_PEEK = 50  # More random lines for manual review\n",
    "KEYWORD_PEEK = 30  # More heuristic hits\n",
    "\n",
    "print(\"DATASETS_ROOT:\", DATASETS_ROOT)\n",
    "print(\"INPUT_JSONL:\", INPUT_JSONL)\n",
    "if not INPUT_JSONL.is_file():\n",
    "    raise FileNotFoundError(f\"Set ZOLOAI_AUDIT_JSONL or run cleaner first. Missing: {INPUT_JSONL}\")\n"
   ]
  },
