   "source": [
    "## 7) Synthetic Gap Filling (Optional)\n",
    "\n",
    "If the audit above shows gaps in **STEM** or **Conversational** data, use this cell to generate a synthetic \"Seed Dataset\" to improve model variety."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# GENERATE SYNTHETIC ZOLAI DATA\n",
    "RUN_SYNTHETIC_GEN = False  # Set to True to generate data\n",
    "GEN_TYPE = \"STEM\"  # Options: \"STEM\", \"CONVERSATIONAL\", \"NEWS\"\n",
    "\n",
    "if RUN_SYNTHETIC_GEN:\n",
    "    key = os.environ.get(\"GEMINI_API_KEY\") or os.environ.get(\"GOOGLE_API_KEY\")\n",
    "    from google import genai\n",
    "    client = genai.Client(api_key=key)\n",
    "    \n",
    "    prompts = {\n",
    "        \"STEM\": \"Generate 100 high-quality Zolai (Tedim) sentences about Science, Technology, Engineering, and Mathematics (STEM). Use modern terminology.\",\n",
    "        \"CONVERSATIONAL\": \"Generate 50 Zolai (Tedim) multi-turn dialogues between an AI assistant and a human user. Keep it natural and informal.\",\n",
    "        \"NEWS\": \"Generate 50 Zolai (Tedim) news snippets about international current events, finance, and sports.\"\n",
    "    }\n",
    "    \n",
    "    print(f\"Generating {GEN_TYPE} data...\")\n",
    "    resp = client.models.generate_content(\n",
    "        model=\"gemini-2.0-flash\",\n",
    "        contents=prompts.get(GEN_TYPE, prompts[\"STEM\"])\n",
    "    )\n",
    "    \n",
    "    out_file = OUT_DIR / f\"synthetic_zolai_{GEN_TYPE.lower()}.jsonl\"\n",
    "    with open(out_file, \"w\", encoding=\"utf-8\") as f:\n",
    "        for line in resp.text.split('\\n'):\n",
    "            line = line.strip()\n",
    "            if line and not line.startswith(\"#\"):\n",
    "                f.write(json.dumps({\"text\": line, \"source\": f\"gemini_synthetic_{GEN_TYPE.lower()}\"}, ensure_ascii=False) + \"\\n\")\n",
    "    print(f\"Done! Saved to {out_file}\")\n",
    "else:\n",
    "    print(\"Set RUN_SYNTHETIC_GEN = True to generate gap-filling data.\")"
   ]
  }
 ]
}