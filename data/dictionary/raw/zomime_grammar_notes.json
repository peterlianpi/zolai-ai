      },
      {
        "label": "Mid Tone",
        "description": "Normal speaking pitch",
        "zolai": "Maw ka"
      },
      {
        "label": "Low Tone",
        "description": "Voice drops slightly",
        "zolai": "Lungdam"
      },
      {
        "label": "Falling Tone",
        "description": "Start high, end low",
